# myAgent 环境变量配置模板
# 使用方法: cp .env.example .env 然后编辑 .env

# LLM 服务地址（本地模型如 Ollama/vLLM 的 API 地址）
LLM_BASE_URL=http://localhost:8080/v1

# LLM API Key（本地模型通常留空）
LLM_API_KEY=

# LLM 模型名称
LLM_MODEL=qwen3-4b

# 超时时间（秒）
LLM_TIMEOUT=120

# 最大 token 数
LLM_MAX_TOKENS=1024

# 温度参数
LLM_TEMPERATURE=0.7

# 是否开启流式输出
LLM_STREAM=false

# 嵌入模型名称
EMBEDDING_MODEL=text-embedding-3-small

# 向量数据库类型
VECTOR_STORE_TYPE=chroma

# SQLite 数据库文件路径
AGENT_DB_PATH=agent_engine.db

# 最大工作线程数
AGENT_MAX_WORKERS=10

# JWT 密钥（生产环境必须修改！）
JWT_SECRET_KEY=change-this-to-a-random-secret-key

# 服务器地址和端口
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
