{
  "meta": {
    "name": "data_analyzer",
    "display_name": "数据分析",
    "description": "自动化数据分析，支持 EDA、统计分析和可视化报告生成",
    "version": "1.0.0",
    "author": "",
    "category": "data",
    "tags": ["data", "analysis", "eda", "statistics", "visualization"],
    "license": "MIT",
    "created_at": "2026-05-31",
    "updated_at": "2026-05-31",
    "homepage": "",
    "source_url": ""
  },
  "trigger": {
    "auto_trigger": true,
    "trigger_keywords": [
      "analysis",
      "分析",
      "数据",
      "eda",
      "探索性分析",
      "statistics",
      "统计",
      "可视化",
      "chart",
      "plot"
    ],
    "negative_keywords": [
      "deploy",
      "部署",
      "review",
      "审查"
    ],
    "match_mode": "any",
    "priority": 6,
    "min_confidence": 0.5
  },
  "parameters": [
    {
      "name": "data_path",
      "type": "string",
      "description": "数据文件路径",
      "required": true,
      "default": null
    },
    {
      "name": "analysis_type",
      "type": "string",
      "description": "分析类型",
      "required": false,
      "default": "eda",
      "enum": ["eda", "statistics", "visualization", "time_series"]
    },
    {
      "name": "output_format",
      "type": "string",
      "description": "输出格式",
      "required": false,
      "default": "report",
      "enum": ["report", "html", "notebook"]
    }
  ],
  "references": [
    "references/pandas_best_practices.md",
    "references/visualization_guide.md"
  ],
  "scripts": {
    "analyze": "scripts/analyze_data.py"
  },
  "tools": ["file", "terminal", "vision"],
  "dependencies": ["pandas", "numpy", "matplotlib", "seaborn"]
}
